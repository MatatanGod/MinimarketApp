<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".RegistroProductoActivity">

    <!-- ═══ TOOLBAR ═══ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        app:elevation="3dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FFFFFF"
            app:navigationIcon="@drawable/icono_regresar_pantalla"
            app:navigationIconTint="#1A1A2E"
            app:title="Registro de Producto"
            app:titleCentered="true"
            app:titleTextColor="#1A1A2E"
            app:titleTextAppearance="@style/TextAppearance.MaterialComponents.Headline6" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ═══ CONTENIDO SCROLLABLE ═══ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:paddingBottom="72dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp">

            <!-- ─── SECCIÓN: Foto del producto + Botón Cámara ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <!-- Card imagen del producto -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardImagen"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="14dp"
                    app:cardElevation="4dp"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#F0F4F8">

                        <ImageView
                            android:id="@+id/ivProducto"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            tools:visibility="visible"
                            tools:src="@tools:sample/avatars" />

                        <LinearLayout
                            android:id="@+id/layoutPlaceholder"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@android:drawable/ic_menu_gallery"
                                app:tint="#BDBDBD" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sin foto"
                                android:textColor="#BDBDBD"
                                android:textSize="11sp"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </FrameLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Controles al lado de la imagen -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginStart="20dp">

                    <!-- Botón Tomar foto con cámara -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTomarFoto"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:text="Tomar foto"
                        android:textSize="13sp"
                        android:textColor="#FFFFFF"
                        app:icon="@android:drawable/ic_menu_camera"
                        app:iconTint="#FFFFFF"
                        app:iconSize="18dp"
                        app:iconPadding="6dp"
                        app:backgroundTint="#7B2D8B"
                        app:cornerRadius="22dp"
                        android:layout_marginBottom="10dp" />

                    <!-- Botón Galería -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGaleria"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:text="Galería"
                        android:textSize="12sp"
                        android:textColor="#7B2D8B"
                        app:icon="@android:drawable/ic_menu_gallery"
                        app:iconTint="#7B2D8B"
                        app:iconSize="16dp"
                        app:iconPadding="6dp"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="#7B2D8B"
                        app:strokeWidth="1.5dp"
                        app:cornerRadius="20dp"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

                </LinearLayout>

            </LinearLayout>

            <!-- ─── Separador sección ─── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#FFC107"
                android:layout_marginBottom="16dp"
                android:alpha="0.5" />

            <!-- ─── CAMPO: Nombre del Producto ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Producto"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="#FFC107"
                app:hintTextColor="#FFC107">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNombreProducto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: Coca Cola 3 litros"
                    android:textSize="14sp"
                    android:inputType="textCapSentences" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ─── CAMPOS: Stock + Categoría ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stock Actual"
                        android:textColor="#1A1A2E"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="#FFC107"
                        app:hintTextColor="#FFC107">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etStockActual"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="0"
                            android:textSize="14sp"
                            android:inputType="number" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.4"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Categoría"
                        android:textColor="#1A1A2E"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense.ExposedDropdownMenu"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="#FFC107"
                        app:hintTextColor="#FFC107">

                        <AutoCompleteTextView
                            android:id="@+id/spinnerCategoria"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Seleccionar"
                            android:inputType="none"
                            android:textSize="13sp" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- ─── CAMPO: Proveedor ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proveedor"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="#FFC107"
                app:hintTextColor="#FFC107">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProveedor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: Empresa AJE"
                    android:textSize="14sp"
                    android:inputType="textCapSentences" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ─── CAMPOS: Precio Compra + Precio Venta + Ganancia ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Precios"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <!-- Precio compra -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Compra"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:layout_marginBottom="2dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="#FFC107"
                        app:prefixText="S/ ">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPrecioCompra"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="0.00"
                            android:textSize="14sp"
                            android:inputType="numberDecimal"
                            tools:text="1.50" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Precio venta -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Venta"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:layout_marginBottom="2dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxCornerRadiusTopStart="10dp"
                        app:boxCornerRadiusTopEnd="10dp"
                        app:boxCornerRadiusBottomStart="10dp"
                        app:boxCornerRadiusBottomEnd="10dp"
                        app:boxStrokeColor="#FFC107"
                        app:prefixText="S/ ">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPrecioVenta"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="0.00"
                            android:textSize="14sp"
                            android:inputType="numberDecimal"
                            tools:text="2.00" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Ganancia (calculada automáticamente) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ganancia"
                        android:textColor="#64748B"
                        android:textSize="11sp"
                        android:layout_marginBottom="2dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#4CAF50"
                        app:strokeWidth="1dp"
                        app:cardBackgroundColor="#E8F5E9">

                        <TextView
                            android:id="@+id/tvGanancia"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="S/ 0.00"
                            android:textColor="#2E7D32"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            tools:text="S/ 0.50" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>

            <!-- ─── CAMPO: Código Único/Barras + Botón Scanner ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Código Único / Barras"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxStrokeColor="#FFC107"
                    app:hintTextColor="#FFC107">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCodigoBarras"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Escanear o ingresar código"
                        android:textSize="13sp"
                        android:inputType="number"
                        android:fontFamily="monospace"
                        tools:text="785411186865575" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Botón Scanner (morado) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnScanner"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="0dp"
                    app:icon="@android:drawable/ic_menu_view"
                    app:iconSize="26dp"
                    app:iconTint="#FFFFFF"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:backgroundTint="#7B2D8B"
                    app:cornerRadius="14dp"
                    style="@style/Widget.MaterialComponents.Button.Icon"
                    android:contentDescription="Abrir escáner" />

            </LinearLayout>

            <!-- ─── CAMPO: Descripción ─── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textColor="#1A1A2E"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="#FFC107"
                app:hintTextColor="#FFC107"
                app:counterEnabled="true"
                app:counterMaxLength="200">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ej: Esta bebida se vende mucho en tiempos de verano"
                    android:textSize="14sp"
                    android:minLines="3"
                    android:maxLines="5"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textCapSentences"
                    android:maxLength="200" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ─── BOTÓN GUARDAR ─── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuardar"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_gravity="center_horizontal"
                android:paddingHorizontal="48dp"
                android:text="Guardar"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                app:icon="@android:drawable/ic_menu_save"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconPadding="8dp"
                app:iconTint="#1A1A2E"
                app:backgroundTint="#FFC107"
                app:cornerRadius="30dp"
                app:elevation="4dp"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- ═══ BOTTOM NAVIGATION ═══ -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_gravity="bottom"
        android:background="#4CAF50"
        app:itemIconTint="#FFFFFF"
        app:itemTextColor="#FFFFFF"
        app:itemActiveIndicatorColor="#33FFFFFF"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>